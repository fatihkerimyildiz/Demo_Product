@model EntityLayer.Concrete.Customer

@{
    ViewData["Title"] = "AddCustomer";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<form method="post">
    @Html.Label("Müşteri Adı")
    @Html.TextBoxFor(x => x.Name, new { @class = "form-control", placeholder = "Müşteri Adını Giriniz" })
    <br />
    @Html.Label("Müşterinin Şehri")
    @Html.TextBoxFor(x => x.City, new { @class = "form-control", placeholder = "Müşterinin Şehrini Giriniz" })
    <br />
    @Html.Label("Meslek Seçiniz")
    @Html.DropDownListFor(x => x.JobID, (List<SelectListItem>)ViewBag.v, new { @class = "form-control" })
    <br />
    <button class="btn btn-primary">Müşteri Ekle</button>

</form>